---
/**
 * CROFooter — Full compliance footer for /cro-op.
 * Deep navy, 3 location contacts, trust badges, legal disclaimers, policy links.
 * Uses badge IMAGES from /images/badges/ — not SVGs.
 */

const LOCATIONS = [
  { name: "Richmond",      phone: "(804) 346-4636", tel: "tel:8043464636" },
  { name: "Virginia Beach", phone: "(757) 612-4428", tel: "tel:7576124428" },
  { name: "Newport News",  phone: "(757) 806-6263", tel: "tel:7578066263" },
] as const;

const DISCLAIMERS = [
  "Treatment requires a clinical evaluation and is provided only when medically appropriate.",
  "Individual results vary. Treatment is provided by licensed providers at Men's Wellness Centers.",
  "The information presented on this website is for general informational purposes only and is not intended to constitute medical advice, diagnosis, or treatment. Nothing on this website should be relied upon as a substitute for an in-person evaluation with a licensed healthcare professional. Always consult with a qualified provider regarding any questions about your health or treatment options.",
  "Men's Wellness Centers provides care through in-center visits at its Virginia locations. All lab work, evaluations, and treatments are conducted on-site by licensed providers.",
  "Testimonials and reviews reflect individual experiences only and are not intended to represent typical outcomes or make medical claims.",
];

const year = new Date().getFullYear();

const linkStyle = "color: rgba(255,255,255,0.50); text-decoration: none; display: inline-flex; align-items: center; min-height: 44px;";
---

<footer
  style="background: var(--brand-navy); font-family: var(--font-body);"
>
  <div style="padding: 48px 24px 0; max-width: 1200px; margin: 0 auto;">

    <!-- Row 1: Logo + Contact -->
    <div
      class="footer-top-grid"
      style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-bottom: 40px;"
    >
      <!-- Brand column -->
      <div>
        <img
          src="/logos/Text_Logo_white.webp"
          alt="Men's Wellness Centers"
          width={200}
          height={40}
          loading="lazy"
          decoding="async"
          style="height: 40px; width: auto; opacity: 0.9;"
        />
        <p
          style="font-size: 13px; color: rgba(255,255,255,0.45); margin-top: 12px; line-height: 1.5;"
        >
          &copy; {year} Men&rsquo;s Wellness Centers.<br />
          All rights reserved.
        </p>
      </div>

      <!-- Contact column -->
      <div>
        <h3
          style="font-family: var(--font-display); font-size: 18px; font-weight: 700; color: var(--white); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 16px;"
        >
          Contact
        </h3>
        <div style="display: flex; flex-direction: column; gap: 10px;">
          {LOCATIONS.map((loc) => (
            <a
              href={loc.tel}
              style="display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.75); text-decoration: none; font-size: 14px; line-height: 1.5;"
            >
              <!-- Phone icon -->
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="var(--orange)"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                style="flex-shrink: 0;"
              >
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.65 3.09 2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9a16 16 0 0 0 6.91 6.91l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
              </svg>
              <span style="font-weight: 600;">{loc.name}:</span>{" "}
              {loc.phone}
            </a>
          ))}
          <a
            href="mailto:info@menswellnesscenters.com"
            style="display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.75); text-decoration: none; font-size: 14px; margin-top: 4px;"
          >
            <!-- Mail icon -->
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--orange)"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              style="flex-shrink: 0;"
            >
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
              <polyline points="22,6 12,13 2,6" />
            </svg>
            info@menswellnesscenters.com
          </a>
        </div>
      </div>
    </div>

    <!-- Row 2: Trust badges -->
    <div
      style="border-top: 1px solid rgba(255,255,255,0.12); padding-top: 32px; display: flex; align-items: center; justify-content: center; gap: 40px; flex-wrap: wrap;"
    >
      <img
        src="/images/badges/clia-color.webp"
        alt="CLIA Certified"
        width={120}
        height={52}
        loading="lazy"
        decoding="async"
        style="height: 52px; width: auto;"
      />
      <a
        href="https://www.legitscript.com/websites/?checker_keywords=menswellnesscenters.com"
        target="_blank"
        rel="noopener noreferrer"
      >
        <img
          src="/images/badges/legitscript-color.webp"
          alt="LegitScript Certified"
          width={110}
          height={64}
          loading="lazy"
          decoding="async"
          style="height: 64px; width: auto;"
        />
      </a>
      <img
        src="/images/badges/hipaa-color.webp"
        alt="HIPAA Compliant"
        width={120}
        height={52}
        loading="lazy"
        decoding="async"
        style="height: 52px; width: auto;"
      />
    </div>

    <!-- Row 3: Legal disclaimers -->
    <div
      style="border-top: 1px solid rgba(255,255,255,0.12); margin-top: 32px; padding-top: 24px; display: flex; flex-direction: column; gap: 12px;"
    >
      {DISCLAIMERS.map((text) => (
        <p
          style="font-size: 11px; line-height: 1.5; color: rgba(255,255,255,0.50); margin: 0; overflow-wrap: break-word;"
        >
          {text}
        </p>
      ))}
    </div>

    <!-- Bottom bar: policy links -->
    <div
      class="footer-policy-bar"
      style="border-top: 1px solid rgba(255,255,255,0.12); margin-top: 24px; padding-top: 16px; padding-bottom: 24px; display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 0; font-size: 11px; font-weight: 700; letter-spacing: 0.09em; text-transform: uppercase; color: rgba(255,255,255,0.50);"
    >
      <span class="footer-policy-item">&copy; {year} Men&rsquo;s Wellness Centers</span>
      <a href="/prescribing-policy" style={linkStyle} class="footer-policy-item">Safety Policy</a>
      <a href="/terms-of-service" style={linkStyle} class="footer-policy-item">Terms of Service</a>
      <a
        href="https://menswellnesscenters.com/privacy-practices/"
        target="_blank"
        rel="noopener noreferrer"
        style={linkStyle}
        class="footer-policy-item"
      >Privacy Policy</a>
      <a
        href="https://menswellnesscenters.com/privacy-practices/#hipaa"
        target="_blank"
        rel="noopener noreferrer"
        style={linkStyle}
      >HIPAA Notice</a>
    </div>
  </div>
</footer>

<style>
  @media (max-width: 640px) {
    .footer-top-grid {
      grid-template-columns: 1fr !important;
    }
    .footer-policy-bar {
      flex-direction: column;
      align-items: center;
      gap: 8px !important;
    }
  }
  @media (min-width: 768px) {
    .footer-policy-item::after {
      content: '|';
      margin: 0 12px;
      opacity: 0.4;
    }
    .footer-policy-item:last-child::after {
      content: '';
      margin: 0;
    }
  }
</style>
