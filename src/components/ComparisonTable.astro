---
const ROWS = [
  { feature: "Real In-Person Care",      mwc: "check", others: "x",     trad: "check" },
  { feature: "Provider-Led Visits",      mwc: "check", others: "x",     trad: "check" },
  { feature: "Men's Health Experts",     mwc: "check", others: "x",     trad: "dash" },
  { feature: "Root-Cause Treatment",     mwc: "check", others: "x",     trad: "x" },
  { feature: "In-Center Labs",           mwc: "check", others: "x",     trad: "dash" },
  { feature: "60-Minute Visit",          mwc: "check", others: "x",     trad: "x" },
  { feature: "Transparent Pricing",      mwc: "check", others: "check", trad: "x" },
  { feature: "Ongoing Monitoring",       mwc: "check", others: "x",     trad: "dash" },
];

type CellKind = "check" | "x" | "dash";
function cellIcon(kind: CellKind) {
  if (kind === "check") return '<span style="color:#3FB950;font-size:20px;line-height:1;">✓</span>';
  if (kind === "x") return '<span style="color:#9CA3AF;font-size:18px;line-height:1;">✕</span>';
  return '<span style="color:#9CA3AF;font-size:20px;line-height:1;">–</span>';
}
---
<section style="background: var(--brand-cream);">
  <div class="max-w-[1320px] mx-auto px-5 sm:px-6 py-12">
    <!-- Navy card -->
    <div style="background: #0B1029; border-radius: 18px; overflow: hidden;">
      <div class="grid grid-cols-1 md:grid-cols-[0.85fr_1.6fr] gap-0 md:gap-12 p-8 md:p-14 items-start">

        <!-- Left -->
        <div class="flex flex-col justify-between mb-8 md:mb-0" style="min-height: 200px;">
          <div>
            <h2 style="font-family: var(--font-display); font-weight: 700; text-transform: uppercase; color: #fff; font-size: clamp(28px, 4vw, 42px); line-height: 1.05; letter-spacing: 0.5px;">
              Men's Wellness Centers <span style="color: var(--brand-cta);">vs.</span><br />the rest
            </h2>
            <p style="color: #E7DDD2; font-size: 15px; line-height: 1.5; margin-top: 16px; max-width: 340px; font-family: var(--font-body);">
              Because men deserve real care. In person, provider-led, and built around lasting results.
            </p>
          </div>
          <a
            href="#hero-form"
            onclick="event.preventDefault(); document.getElementById('hero-form')?.scrollIntoView({behavior:'smooth'});"
            style="display: inline-flex; align-items: center; justify-content: center; background: var(--brand-cta); color: #fff; font-family: var(--font-display); font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; font-size: 15px; height: 56px; padding: 0 34px; border-radius: 60px; margin-top: 32px; border: none; cursor: pointer; text-decoration: none; align-self: flex-start;"
          >
            Book Your 60-Minute Visit
          </a>
        </div>

        <!-- Right: table -->
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse; min-width: 400px;">
            <thead>
              <tr>
                <th style="text-align: left; padding: 12px 16px 12px 0;" />
                <th style="text-align: center; background: #F5F3F0; padding: 12px 8px; border-radius: 10px 10px 0 0; width: 130px;">
                  <img src="/logos/mwc-logo-navy.webp" onerror="this.src='/logos/mwc-logo-navy.jpg'" alt="Men's Wellness Centers" style="height: 32px; width: auto; margin: 0 auto;" />
                </th>
                <th style="text-align: center; background: #161B3A; padding: 12px 8px; border-radius: 10px 10px 0 0; width: 110px;">
                  <span style="font-family: var(--font-body); font-size: 12px; font-weight: 700; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.08em;">Telehealth</span>
                </th>
                <th style="text-align: center; background: #1E244A; padding: 12px 8px; border-radius: 10px 10px 0 0; width: 110px;">
                  <span style="font-family: var(--font-body); font-size: 12px; font-weight: 700; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.08em;">Traditional</span>
                </th>
              </tr>
            </thead>
            <tbody>
              {ROWS.map((row, i) => (
                <tr>
                  <td style={`padding: 11px 16px 11px 0; font-family: var(--font-body); font-size: 13px; color: #e8e6e2; font-weight: 500; border-top: 1px solid rgba(255,255,255,0.07);`}>
                    {row.feature}
                  </td>
                  <td style="text-align: center; background: #F5F3F0; padding: 11px 8px; border-top: 1px solid rgba(200,200,200,0.3);" set:html={cellIcon(row.mwc as CellKind)} />
                  <td style="text-align: center; background: #161B3A; padding: 11px 8px; border-top: 1px solid rgba(255,255,255,0.05);" set:html={cellIcon(row.others as CellKind)} />
                  <td style="text-align: center; background: #1E244A; padding: 11px 8px; border-top: 1px solid rgba(255,255,255,0.05);" set:html={cellIcon(row.trad as CellKind)} />
                </tr>
              ))}
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </div>
</section>
