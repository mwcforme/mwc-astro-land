---
import { TESTIMONIALS, GBP_REVIEWS_URL } from '../data/testimonials';
---
<section id="results" style="background: var(--brand-cream);">
  <div class="max-w-[1200px] mx-auto px-6 py-14 md:py-20">

    <!-- Header -->
    <div class="text-center mb-10 md:mb-12">
      <p style="font-family: var(--font-body); font-size: 12px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--brand-navy); margin-bottom: 12px; text-align: center;">
        Member Outcomes
      </p>
      <h2 style="font-family: var(--font-display); font-weight: 700; text-transform: uppercase; color: var(--brand-navy); font-size: clamp(26px, 3vw, 38px); letter-spacing: 0.02em; margin-bottom: 10px;">
        Real Members. Real Experiences.
      </h2>

      <!-- Aggregate rating strip -->
      <div style="display: inline-flex; align-items: center; gap: 12px; flex-wrap: wrap; justify-content: center;">
        <div style="display: flex; align-items: center; gap: 2px;">
          {[1,2,3,4,5].map(() => (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--brand-cta)" stroke="var(--brand-cta)" stroke-width="1" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          ))}
        </div>
        <span style="font-size: 17px; font-weight: 700; color: var(--brand-navy); font-family: var(--font-body);">4.9</span>
        <span style="font-size: 14px; color: var(--c-text-on-light-muted);">·</span>
        <a
          href={GBP_REVIEWS_URL}
          target="_blank"
          rel="noopener noreferrer"
          style="display: inline-flex; align-items: center; gap: 4px; font-size: 14px; color: var(--brand-navy); text-decoration: underline; text-underline-offset: 3px; font-family: var(--font-body);"
        >
          191 verified Google reviews
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
        </a>
      </div>
    </div>

    <!-- Review cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {TESTIMONIALS.map((t) => (
        <div style="border: 1px solid rgba(11,16,41,0.08); box-shadow: 0 2px 16px rgba(11,16,41,0.06); border-radius: 16px; padding: 24px; display: flex; flex-direction: column; background: var(--bg-white);">

          <!-- Card header -->
          <div style="display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px;">
            {t.photoUrl ? (
              <img
                src={t.photoUrl}
                alt={`${t.name} profile`}
                width="44"
                height="44"
                loading="lazy"
                decoding="async"
                style="width: 44px; height: 44px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(11,16,41,0.08); flex-shrink: 0;"
              />
            ) : (
              <div style="width: 44px; height: 44px; border-radius: 50%; background: var(--brand-navy); color: #fff; display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-weight: 700; font-size: 16px; flex-shrink: 0;">
                {t.name.charAt(0)}
              </div>
            )}

            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 16px; font-family: var(--font-body); font-weight: 700; color: var(--brand-navy); line-height: 1.2;">{t.name}</div>
              <div style="font-size: 13px; margin-top: 2px; font-family: var(--font-body); color: var(--c-text-on-light-muted);">{t.relativeTime}</div>
            </div>

            <!-- Google G -->
            <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true">
              <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.4 29.3 35.5 24 35.5c-6.4 0-11.5-5.1-11.5-11.5S17.6 12.5 24 12.5c2.9 0 5.6 1.1 7.7 2.9l5.7-5.7C33.6 6.4 29 4.5 24 4.5 13.2 4.5 4.5 13.2 4.5 24S13.2 43.5 24 43.5c10.5 0 19.5-7.6 19.5-19.5 0-1.2-.1-2.4-.4-3.5z"/>
              <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.6 16 19 12.5 24 12.5c2.9 0 5.6 1.1 7.7 2.9l5.7-5.7C33.6 6.4 29 4.5 24 4.5 16.4 4.5 9.8 8.7 6.3 14.7z"/>
              <path fill="#4CAF50" d="M24 43.5c5 0 9.5-1.7 13-4.6l-6-5.1c-2 1.4-4.4 2.2-7 2.2-5.3 0-9.7-3.1-11.3-7.5l-6.6 5.1C9.7 39.2 16.3 43.5 24 43.5z"/>
              <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.7 2-2.1 3.7-3.9 5l6 5.1c4.2-3.9 6.6-9.6 6.6-16 0-1.2-.1-2.4-.4-3.5z"/>
            </svg>
          </div>

          <!-- Stars -->
          <div style="display: flex; align-items: center; gap: 2px; margin-bottom: 12px;">
            {[1,2,3,4,5].map(() => (
              <svg width="15" height="15" viewBox="0 0 24 24" fill="var(--brand-cta)" stroke="var(--brand-cta)" stroke-width="1" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>

          <!-- Quote -->
          <p style="font-size: 16px; flex: 1; margin-bottom: 16px; font-family: var(--font-body); line-height: 1.6; color: var(--c-text-on-light);">
            "{t.quote}"
          </p>

          <!-- Verified badge -->
          <div style="display: inline-flex; align-items: center; gap: 6px; margin-top: auto; font-size: 11px; font-family: var(--font-body); font-weight: 600; color: #1a73e8; letter-spacing: 0.02em;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#1a73e8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Verified Google Review
          </div>
        </div>
      ))}
    </div>

    <!-- Footer -->
    <div class="mt-10 text-center">
      <p style="font-style: italic; margin-bottom: 20px; font-size: 13px; color: var(--c-text-on-light-muted); font-family: var(--font-body);">
        Reviews reflect individual experiences. Individual results vary.{" "}
        <a href={GBP_REVIEWS_URL} target="_blank" rel="noopener noreferrer" style="color: var(--brand-navy); text-decoration: underline; text-underline-offset: 3px; padding: 0 2px;">
          See all 191 reviews →
        </a>
      </p>
      <a
        href="#hero-form"
        onclick="event.preventDefault(); document.getElementById('hero-form')?.scrollIntoView({behavior:'smooth'});"
        style="display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-weight: 700; border: none; height: 56px; min-height: 56px; background: var(--brand-cta); color: var(--c-text-on-dark); font-size: 16px; letter-spacing: 0.06em; font-family: var(--font-display); text-transform: uppercase; white-space: nowrap; border-radius: 60px; padding: 0 32px; text-decoration: none; cursor: pointer;"
      >
        Book in-person visit
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
