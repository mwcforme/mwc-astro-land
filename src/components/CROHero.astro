---
import HeroLeadForm from './HeroLeadForm';
import { GBP_REVIEWS_URL } from '../data/testimonials';
---

<section id="hero" style="position: relative; background: var(--navy, #0B1029); overflow: hidden; padding: clamp(40px, 8vw, 100px) var(--gutter) clamp(56px, 10vw, 120px);">
  <!-- Background portrait image -->
  <img
    src="/images/cro/hero-portrait-v3.jpg"
    alt=""
    class="hero-bg-img"
    aria-hidden="true"
    loading="eager"
  />

  <!-- Grid layout -->
  <div class="hero-grid" style="position: relative; z-index: 1; display: grid; grid-template-columns: 1fr; gap: 40px; max-width: var(--maxw); margin: 0 auto; padding-top: clamp(0px, 2vw, 32px); align-items: start;">

    <!-- Left column -->
    <div style="max-width: 600px;">
      <!-- H1 -->
      <h1 style="font-family: var(--font-display); font-weight: 700; line-height: var(--lh-display, 0.95); text-transform: uppercase; margin: 0 0 20px; letter-spacing: -0.01em;">
        <span style="display: block; color: #FFFFFF; font-size: clamp(26px, 7vw, 100px);">YOU'RE NOT JUST "AGING."</span>
        <span style="display: block; color: var(--orange, #E8670A); font-size: clamp(26px, 7vw, 100px);">LET'S FIND THE REAL ISSUE.</span>
      </h1>

      <!-- Star rating -->
      <a href={GBP_REVIEWS_URL} target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 8px; text-decoration: none; margin-bottom: 24px;">
        <span style="display: flex; align-items: center; gap: 2px;" aria-label="5 stars">
          {Array.from({length: 5}).map(() => (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#C9A961" aria-hidden="true">
              <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
            </svg>
          ))}
        </span>
        <span style="font-family: var(--font-body); font-size: 13px; color: rgba(255,255,255,0.75); font-weight: 500;">4.9 · 191 verified Google reviews</span>
      </a>

      <!-- Body text (hidden on mobile) -->
      <p class="hero-body-text" style="font-family: var(--font-body); font-size: clamp(15px, 1.5vw, 17px); color: rgba(255,255,255,0.80); line-height: 1.65; margin: 0 0 28px; max-width: 520px;">
        They told you it's part of getting older. It's not. Low testosterone, ED, and stubborn weight have real, measurable causes. This is all we do, and that focus is the difference.
      </p>

      <!-- Symptom bullets -->
      <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px;">
        <li style="display: flex; align-items: flex-start; gap: 10px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--orange, #E8670A)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:2px;" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          <span style="font-family: var(--font-body); font-size: 15px; color: rgba(255,255,255,0.85); line-height: 1.5;">Exhausted by noon, no matter how much you sleep.</span>
        </li>
        <li style="display: flex; align-items: flex-start; gap: 10px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--orange, #E8670A)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:2px;" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          <span style="font-family: var(--font-body); font-size: 15px; color: rgba(255,255,255,0.85); line-height: 1.5;">Gaining weight despite doing everything right.</span>
        </li>
        <li style="display: flex; align-items: flex-start; gap: 10px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--orange, #E8670A)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:2px;" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          <span style="font-family: var(--font-body); font-size: 15px; color: rgba(255,255,255,0.85); line-height: 1.5;">Low drive or performance changes you didn't used to have.</span>
        </li>
        <li class="hero-bullet-desktop" style="display: flex; align-items: flex-start; gap: 10px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--orange, #E8670A)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:2px;" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          <span style="font-family: var(--font-body); font-size: 15px; color: rgba(255,255,255,0.85); line-height: 1.5;">Your doctor ran labs and said you're fine. You're not fine.</span>
        </li>
        <li class="hero-bullet-desktop" style="display: flex; align-items: flex-start; gap: 10px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--orange, #E8670A)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:2px;" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          <span style="font-family: var(--font-body); font-size: 15px; color: rgba(255,255,255,0.85); line-height: 1.5;">You want answers, not another subscription.</span>
        </li>
      </ul>
    </div>

    <!-- Right column: lead form -->
    <div id="hero-form" style="scroll-margin-top: 80px;">
      <HeroLeadForm client:load />
    </div>
  </div>
</section>
