---
import HeroLeadForm from './HeroLeadForm';
import { GBP_REVIEWS_URL } from '../data/testimonials';

const SYMPTOM_BULLETS = [
  "Exhausted by noon, no matter how much you sleep.",
  "Gaining weight despite doing everything right.",
  "Low drive or performance changes you didn't used to have.",
  "Your doctor ran labs and said you're fine. You're not fine.",
  "You want answers, not another subscription.",
];
---

<section
  id="hero"
  style="position: relative; background: var(--navy, #0B1029); display: flex; align-items: center; overflow: hidden; padding: clamp(16px, 3vw, 64px) clamp(16px, 4vw, 32px) clamp(32px, 5vw, 80px);"
>
  <!-- Background portrait image -->
  <div aria-hidden="true" style="position: absolute; inset: 0; z-index: 0; overflow: hidden;">
    <img
      src="/images/cro/hero-portrait-v3.jpg"
      alt=""
      class="hero-bg-img"
      loading="eager"
      decoding="async"
    />
  </div>

  <!-- Skip-to-form a11y link -->
  <a
    href="#hero-form"
    class="skip-to-form"
    style="position: absolute; left: -9999px; top: 0; z-index: 100; background: var(--orange, #E8670A); color: #FFFFFF; padding: 8px 16px; border-radius: var(--radius-btn, 12px); font-family: var(--font-body); font-size: 14px;"
  >
    Skip to form
  </a>

  <!-- Content grid -->
  <div
    class="hero-grid"
    style="max-width: var(--maxw); width: 100%; margin: 0 auto; display: grid; grid-template-columns: 1fr; gap: clamp(16px, 4vw, 48px); align-items: center; position: relative; z-index: 1;"
  >
    <!-- Left column: Copy -->
    <div style="max-width: 600px;">
      <!-- H1 -->
      <h1
        class="cro-hero-headline"
        style="font-family: var(--font-display); font-weight: 700; text-transform: uppercase; line-height: 1.08; margin: 0; color: #FFFFFF;"
      >
        YOU'RE NOT JUST "AGING."<br />
        <span style="color: var(--orange, #E8670A);">LET'S FIND THE REAL ISSUE.</span>
      </h1>

      <!-- Star rating -->
      <a
        href={GBP_REVIEWS_URL}
        target="_blank"
        rel="noopener noreferrer"
        style="display: inline-flex; align-items: center; gap: 8px; margin-top: 8px; text-decoration: none; color: rgba(255,255,255,0.65); font-family: var(--font-body); font-size: 14px; font-weight: 500;"
      >
        <span style="display: flex; gap: 2px;" aria-label="5 stars">
          {Array.from({length: 5}).map(() => (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#C9A961" aria-hidden="true">
              <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
            </svg>
          ))}
        </span>
        <span>4.9 · 191 verified Google reviews</span>
      </a>

      <!-- Body paragraph — hidden on mobile -->
      <p
        class="hero-body-text"
        style="font-family: Montserrat, sans-serif; font-size: 16px; line-height: 1.7; color: #FFFFFF; margin-top: 16px; margin-bottom: 16px;"
      >
        They told you it's part of getting older. It's not. Low
        testosterone, ED, and stubborn weight have real, measurable causes.
        This is all we do, and that focus is the difference.
      </p>

      <!-- Symptom bullets — last 2 hidden on mobile -->
      <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0;">
        {SYMPTOM_BULLETS.map((text, i) => (
          <li
            class={i >= 3 ? "hero-bullet-desktop" : ""}
            style="display: flex; align-items: flex-start; gap: 8px; font-family: Montserrat, sans-serif; font-size: 14px; line-height: 1.55; margin-bottom: 4px; color: var(--cream, #F5F3F0);"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--orange, #E8670A)"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              style="flex-shrink: 0; margin-top: 3px;"
              aria-hidden="true"
            >
              <polyline points="9 18 15 12 9 6"/>
            </svg>
            <span>{text}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Right column: Form -->
    <div id="hero-form" class="cro-hero-form-col">
      <HeroLeadForm client:load />
    </div>
  </div>
</section>
