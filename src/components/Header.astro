---
import { PHONE } from '../data/constants';
---
<header
  class="fixed top-0 left-0 right-0 z-50"
  style="background: rgba(11,16,41,0.90); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); height: 64px;"
>
  <div class="flex items-center justify-between px-6 mx-auto h-full" style="max-width: 1200px;">
    <!-- Logo -->
    <a href="/" aria-label="Men's Wellness Centers home" class="inline-flex items-center">
      <img
        src="/logos/Text_Logo_white.webp"
        onerror="this.src='/logos/Text_Logo_white.png'"
        decoding="async"
        loading="eager"
        width="180"
        height="28"
        alt="Men's Wellness Centers"
        style="height: 28px; width: auto;"
      />
    </a>

    <!-- Desktop: phone + CTA -->
    <div class="hidden md:flex items-center gap-4">
      <a
        href={PHONE.tel}
        class="text-sm font-medium transition-opacity hover:opacity-80"
        style="color: var(--c-text-on-dark); font-family: var(--font-body);"
      >
        {PHONE.display}
      </a>
      <a
        href="#hero-form"
        onclick="event.preventDefault(); document.getElementById('hero-form')?.scrollIntoView({behavior:'smooth'});"
        style="padding: 0 22px; border-radius: 60px; box-shadow: 0 4px 16px rgba(232,103,10,0.40); font-family: var(--font-display); font-size: 14px; text-transform: uppercase; letter-spacing: 0.07em; background: var(--brand-cta); color: var(--c-text-on-dark); height: 44px; font-weight: 700; display: inline-flex; align-items: center; gap: 6px; white-space: nowrap; text-decoration: none;"
      >
        Book Appointment
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Mobile: phone icon button -->
    <div class="md:hidden flex items-center">
      <a
        href={PHONE.tel}
        aria-label={`Call ${PHONE.display}`}
        style="box-shadow: 0 4px 16px rgba(232,103,10,0.40); position: relative; display: inline-flex; align-items: center; justify-content: center; border-radius: 50%; width: 52px; height: 52px; background: var(--brand-cta); color: var(--c-text-on-dark);"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.5 11.5a19.79 19.79 0 01-3.07-8.67A2 2 0 012.43 1h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 8.91a16 16 0 006.18 6.18l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
      </a>
    </div>
  </div>
</header>
