---
const included = [
  'Labs drawn and reviewed on-site',
  '60-minute face-to-face provider visit',
  'Personalized treatment protocol (if appropriate)',
  'We do not accept insurance, but FSA, HSA, and financing options are available',
  'No phone tag or waiting rooms',
  'Virginia-licensed providers, every visit',
];

const notFound = [
  'Hidden fees',
  'Automatic subscriptions',
  'Pressure to commit',
  'Call center routing',
];
---

<section
  id="whats-covered"
  style="background: #0B1029; padding: var(--section-y) 24px;"
>
  <div style="max-width: var(--maxw); margin: 0 auto;">
    <!-- Heading -->
    <div style="text-align: center; margin-bottom: clamp(40px, 5vw, 64px);">
      <h2 style="font-family: var(--font-display); font-size: var(--fs-h1); font-weight: 700; color: #FFFFFF; text-transform: uppercase; line-height: 1.1; margin: 0;">
        EVERYTHING&rsquo;S INCLUDED.<br />
        <span style="color: var(--orange);">NO SURPRISES.</span>
      </h2>
      <p style="font-family: var(--font-body); font-size: var(--fs-body); color: #B0ADA8; margin-top: 16px; max-width: 560px; margin-inline: auto;">
        Your first visit is no-cost. Here&rsquo;s exactly what that means.
      </p>
    </div>

    <!-- Two-column grid -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 340px), 1fr)); gap: clamp(20px, 3vw, 32px);">
      <!-- Included card -->
      <div style="background: var(--white); border: 1px solid rgba(11,16,41,0.10); border-radius: var(--cro-card-radius); padding: clamp(28px, 4vw, 40px); box-shadow: var(--shadow-card);">
        <p style="font-family: var(--font-body); font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--orange); margin: 0 0 20px;">
          ✓ What&rsquo;s included
        </p>
        <ul style="list-style: none; margin: 0; padding: 0;">
          {included.map((item) => (
            <li style="display: flex; align-items: flex-start; gap: 12px; margin-bottom: 14px; font-family: var(--font-body); font-size: var(--fs-body); color: var(--cro-text-body); line-height: 1.5;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-top: 4px;" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Not found card -->
      <div style="background: var(--white); border: 1px solid rgba(11,16,41,0.10); border-radius: var(--cro-card-radius); padding: clamp(28px, 4vw, 40px); box-shadow: var(--shadow-card); display: flex; flex-direction: column;">
        <p style="font-family: var(--font-body); font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--orange); margin: 0 0 20px;">
          ✗ What you won&rsquo;t find here
        </p>
        <ul style="list-style: none; margin: 0; padding: 0;">
          {notFound.map((item) => (
            <li style="display: flex; align-items: flex-start; gap: 12px; margin-bottom: 14px; font-family: var(--font-body); font-size: var(--fs-body); color: #374151; line-height: 1.5;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-top: 4px;" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>

        <!-- Stat -->
        <div style="margin-top: auto; padding-top: 28px; border-top: 1px solid rgba(11,16,41,0.08);">
          <p style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; color: var(--orange); margin: 0; line-height: 1;">
            10,000+
          </p>
          <p style="font-family: var(--font-body); font-size: 14px; color: var(--cro-text-body); margin: 8px 0 0; line-height: 1.5;">
            Virginia members since 2015. All at no-cost for the first visit.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
