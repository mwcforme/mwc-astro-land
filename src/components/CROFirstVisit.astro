---
const items = [
  { icon: '/images/icons/clinical_notes_E8670A_transparent.svg',  text: 'A dedicated provider who knows your history and your goals' },
  { icon: '/images/icons/lab_research_E8670A_transparent.svg',    text: 'On-site lab testing with results the same visit' },
  { icon: '/images/icons/pending_actions_E8670A_transparent.svg', text: 'A personalized protocol, tracked and optimized over time' },
  { icon: '/images/icons/3p_E8670A_transparent.svg',              text: 'Direct access to your provider between visits' },
  { icon: '/images/icons/diamond_E8670A_transparent.svg',         text: 'A private, concierge-level experience start to finish' },
  { icon: '/images/icons/payments_E8670A_transparent.svg',        text: 'Transparent cash-pay pricing, no surprises' },
];
---

<section
  id="first-visit"
  style="background: var(--cro-surface-secondary); padding: var(--section-y) 24px;"
>
  <div style="max-width: var(--maxw); margin: 0 auto;">
    <div style="background: var(--navy); border-radius: var(--cro-card-radius); padding: clamp(32px, 6vw, 72px) clamp(24px, 5vw, 64px);">

      <!-- Heading -->
      <h2 style="font-family: var(--font-display); font-size: var(--fs-h1); font-weight: 700; color: var(--white); text-transform: uppercase; line-height: 1.1; margin: 0; text-align: center;">
        WHAT TO EXPECT AT YOUR FIRST VISIT
      </h2>

      <!-- Subtext -->
      <p style="font-family: var(--font-body); font-size: var(--fs-body); color: rgba(255,255,255,0.75); line-height: 1.65; text-align: center; max-width: 720px; margin: 20px auto 0;">
        The average American spends about 18 minutes a year with their primary care doctor.
        <strong style="color: var(--cream);">
          Your first Men&rsquo;s Wellness Centers visit is a 60-minute, face-to-face deep dive
        </strong>,
        with labs, results, and a personalized protocol before you leave.
      </p>

      <!-- Icon grid -->
      <div class="cro-fv-grid">
        {items.map(({ icon, text }) => (
          <div style="text-align: center;">
            <div style="display: inline-flex; margin-bottom: 14px;">
              <img src={icon} alt="" width="48" height="48" loading="lazy" />
            </div>
            <p style="font-family: var(--font-body); font-size: 14px; color: rgba(255,255,255,0.75); line-height: 1.55; margin: 0;">
              {text}
            </p>
          </div>
        ))}
      </div>

      <!-- Trust badges -->
      <div style="display: flex; align-items: center; justify-content: center; gap: clamp(24px, 4vw, 48px); margin-top: clamp(40px, 5vw, 64px); padding-top: clamp(28px, 4vw, 40px); border-top: 1px solid rgba(255,255,255,0.10); flex-wrap: wrap;">
        <img
          src="/images/badges/clia-color.webp"
          alt="CLIA Certified"
          class="cro-trust-badge"
          loading="lazy"
          width="120"
          height="48"
          style="height: 48px; width: auto;"
        />
        <a
          href="https://www.legitscript.com/websites/?checker_keywords=menswellnesscenters.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          <img
            src="/images/badges/legitscript-color.webp"
            alt="LegitScript Certified"
            class="cro-trust-badge"
            loading="lazy"
            width="140"
            height="56"
            style="height: 56px; width: auto;"
          />
        </a>
        <img
          src="/images/badges/hipaa-color.webp"
          alt="HIPAA Compliant"
          class="cro-trust-badge"
          loading="lazy"
          width="120"
          height="48"
          style="height: 48px; width: auto;"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .cro-fv-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(24px, 4vw, 40px);
    margin-top: clamp(36px, 5vw, 56px);
  }
  @media (max-width: 768px) {
    .cro-fv-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .cro-fv-grid { grid-template-columns: 1fr; }
  }
  .cro-trust-badge {
    filter: grayscale(100%) brightness(1.5);
    opacity: 0.7;
    transition: filter 0.3s ease, opacity 0.3s ease;
  }
  .cro-trust-badge:hover {
    filter: grayscale(0%);
    opacity: 1;
  }
</style>
