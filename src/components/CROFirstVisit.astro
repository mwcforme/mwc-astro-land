---
const steps = [
  { time: '0–5 min', label: 'Arrival & Welcome', desc: "You check in, complete a brief intake form, and meet your provider's team. No waiting room anxiety — you're expected." },
  { time: '5–20 min', label: 'Vitals & Blood Draw', desc: 'A clinical team member takes your vitals and draws blood on-site. This is the same panel your protocol will be built from.' },
  { time: '20–45 min', label: 'Provider Consultation', desc: 'Your provider reviews your results, listens to your symptoms, and explains what your numbers mean for how you feel day to day.' },
  { time: '45–60 min', label: 'Protocol & Next Steps', desc: 'You leave with a personalized care plan, your next appointment scheduled, and a clear understanding of what happens next.' },
];
---

<!-- Hidden on mobile -->
<section class="hidden md:block" style="background: var(--cro-surface-primary, #FFFFFF); padding: var(--section-y) var(--gutter);">
  <div style="max-width: var(--maxw); margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 48px;">
      <p style="font-family: var(--font-body); font-size: var(--fs-eyebrow); font-weight: 700; letter-spacing: var(--ls-eyebrow); text-transform: uppercase; color: var(--orange, #E8670A); margin: 0 0 12px;">FIRST VISIT WALKTHROUGH</p>
      <h2 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(28px, 4vw, 48px); color: var(--cro-text-on-light, #0B1029); text-transform: uppercase; line-height: var(--lh-heading); margin: 0 0 16px;">Here's what happens in your first 60 minutes.</h2>
      <p style="font-family: var(--font-body); font-size: clamp(15px, 1.5vw, 17px); color: var(--cro-text-body, #374151); line-height: var(--lh-body); max-width: 540px; margin: 0 auto;">
        No surprises. No extended waits. A structured, provider-led visit designed for men who want answers.
      </p>
    </div>

    <!-- Timeline -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 0; position: relative;">
      {steps.map((step, i) => (
        <div style="position: relative; padding: 0 24px 0 0;">
          <!-- Connector line -->
          {i < steps.length - 1 && (
            <div style="position: absolute; top: 20px; right: 0; width: 24px; height: 2px; background: rgba(11,16,41,0.12);" aria-hidden="true"></div>
          )}
          <!-- Dot -->
          <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--navy, #0B1029); display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
            <span style="font-family: var(--font-display); font-size: 14px; font-weight: 700; color: #fff;">{i + 1}</span>
          </div>
          <p style="font-family: var(--font-body); font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--orange, #E8670A); margin: 0 0 6px;">{step.time}</p>
          <h3 style="font-family: var(--font-display); font-size: 16px; font-weight: 700; color: var(--cro-text-on-light, #0B1029); text-transform: uppercase; margin: 0 0 10px;">{step.label}</h3>
          <p style="font-family: var(--font-body); font-size: 14px; color: var(--cro-text-body, #374151); line-height: 1.65; margin: 0;">{step.desc}</p>
        </div>
      ))}
    </div>

    <div style="text-align: center; margin-top: 48px;">
      <a href="#hero-form" style="display: inline-flex; align-items: center; justify-content: center; height: 56px; padding: 0 40px; background: var(--orange, #E8670A); color: #FFFFFF; font-family: var(--font-display); font-size: 16px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; border-radius: var(--radius-pill, 999px); text-decoration: none; box-shadow: var(--shadow-cta);">
        SCHEDULE MY VISIT
      </a>
    </div>
  </div>
</section>
