<section style="background: var(--brand-navy-deep, #080D1F); padding: var(--section-y) var(--gutter); text-align: center;">
  <div style="max-width: 640px; margin: 0 auto;">
    <p style="font-family: var(--font-body); font-size: var(--fs-eyebrow); font-weight: 700; letter-spacing: var(--ls-eyebrow); text-transform: uppercase; color: var(--orange, #E8670A); margin: 0 0 16px;">TAKE THE FIRST STEP</p>
    <h2 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(28px, 4vw, 48px); color: #FFFFFF; text-transform: uppercase; line-height: var(--lh-heading); margin: 0 0 16px;">Ready to feel like yourself again?</h2>
    <p style="font-family: var(--font-body); font-size: clamp(15px, 1.5vw, 17px); color: rgba(255,255,255,0.70); line-height: var(--lh-body); margin: 0 0 36px;">
      No-cost 60-minute visit. Same-day lab results. Virginia-licensed provider. In person.
    </p>
    <a href="#hero-form" style="display: inline-flex; align-items: center; justify-content: center; gap: 8px; height: 64px; padding: 0 48px; background: var(--orange, #E8670A); color: #FFFFFF; font-family: var(--font-display); font-size: 18px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; border-radius: var(--radius-pill, 999px); text-decoration: none; box-shadow: var(--shadow-cta);">
      BOOK MY NO-COST VISIT
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
    <p style="margin-top: 16px; font-size: 13px; color: rgba(255,255,255,0.40); font-family: var(--font-body);">
      No obligation. Cancel or reschedule anytime, no charge.
    </p>
  </div>
</section>
