---
---

<section style="background: var(--cro-surface-secondary, #ECEAE6); padding: var(--section-y) var(--gutter);">
  <div style="max-width: var(--maxw); margin: 0 auto; background: var(--navy, #0B1029); border-radius: var(--cro-card-radius, 24px); padding: clamp(48px, 8vw, 80px) clamp(24px, 5vw, 64px); text-align: center; position: relative; overflow: hidden;">

    <!-- Background image overlay -->
    <div
      aria-hidden="true"
      style="position: absolute; inset: 0; background-image: url(/images/cro/surfers-sunset.webp); background-size: cover; background-position: center; opacity: 0.12; pointer-events: none;"
    ></div>

    <!-- Content -->
    <div style="position: relative; z-index: 1;">
      <h2 style="font-family: var(--font-display); font-size: var(--fs-h1); font-weight: 700; line-height: var(--lh-heading); text-transform: uppercase; color: #FFFFFF; margin: 0 0 20px;">
        READY TO<br />
        <span style="color: var(--orange, #E8670A);">FEEL THE DIFFERENCE?</span>
      </h2>

      <p style="font-family: var(--font-body); font-size: var(--fs-body); line-height: var(--lh-body); color: rgba(255,255,255,0.75); max-width: 560px; margin: 0 auto 36px;">
        No-cost 60-minute in-person visit. Same-day labs. No insurance needed. FSA &amp; HSA accepted.
      </p>

      <!-- CTA row -->
      <div style="display: flex; flex-direction: column; align-items: center; gap: 12px;">
        <a
          href="#hero-form"
          style="display: inline-flex; align-items: center; justify-content: center; height: 56px; padding: 0 40px; background: var(--orange, #E8670A); color: #FFFFFF; font-family: var(--font-display); font-size: 16px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; border-radius: var(--radius-pill, 999px); text-decoration: none; box-shadow: var(--shadow-cta);"
        >
          BOOK YOUR 60-MINUTE VISIT
        </a>

        <div style="display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;">
          <a
            href="tel:+18663444955"
            style="display: inline-flex; align-items: center; justify-content: center; gap: 8px; height: 44px; padding: 0 24px; background: rgba(255,255,255,0.10); color: rgba(255,255,255,0.80); font-family: var(--font-display); font-size: 14px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; border-radius: var(--radius-pill, 999px); text-decoration: none; border: 1px solid rgba(255,255,255,0.20);"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.5 11.5a19.79 19.79 0 01-3.07-8.67A2 2 0 012.43 1h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 8.91a16 16 0 006.18 6.18l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
            Call
          </a>
          <a
            href="sms:+18663444955?body=Hi%2C%20I%27d%20like%20to%20book%20a%20visit."
            style="display: inline-flex; align-items: center; justify-content: center; gap: 8px; height: 44px; padding: 0 24px; background: rgba(255,255,255,0.10); color: rgba(255,255,255,0.80); font-family: var(--font-display); font-size: 14px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; border-radius: var(--radius-pill, 999px); text-decoration: none; border: 1px solid rgba(255,255,255,0.20);"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            Text
          </a>
        </div>
      </div>

      <!-- Trust microcopy -->
      <p style="font-family: var(--font-body); font-size: 13px; color: rgba(255,255,255,0.50); margin-top: 28px; letter-spacing: 0.02em;">
        3 Virginia locations &middot; HIPAA compliant &middot; LegitScript certified
      </p>
    </div>

  </div>
</section>
