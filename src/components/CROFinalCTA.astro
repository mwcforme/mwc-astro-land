---
/**
 * CROFinalCTA — Pre-footer conversion block for /cro-op.
 * Navy card on cream background with background image overlay,
 * primary + secondary CTAs, trust microcopy.
 */
---

<section
  style="background: var(--cro-surface-secondary); padding: var(--section-y) var(--gutter);"
>
  <div
    style="max-width: var(--maxw); margin: 0 auto; background: var(--navy); border-radius: var(--cro-card-radius); padding: clamp(48px, 8vw, 80px) clamp(24px, 5vw, 64px); text-align: center; position: relative; overflow: hidden;"
  >
    <!-- Background image overlay -->
    <div
      aria-hidden="true"
      style="position: absolute; inset: 0; background-image: url(/images/cro/surfers-sunset.webp); background-size: cover; background-position: center; opacity: 0.12; pointer-events: none;"
    ></div>

    <!-- Content -->
    <div style="position: relative; z-index: 1;">
      <h2
        style="font-family: var(--font-display); font-size: var(--fs-h1); font-weight: 700; line-height: var(--lh-heading); text-transform: uppercase; color: var(--white); margin: 0 0 20px;"
      >
        READY TO<br />
        <span style="color: var(--orange);">FEEL THE DIFFERENCE?</span>
      </h2>

      <p
        style="font-family: var(--font-body); font-size: var(--fs-body); line-height: var(--lh-body); color: rgba(255,255,255,0.75); max-width: 560px; margin: 0 auto 36px;"
      >
        No-cost 60-minute in-person visit. Same-day labs. No insurance
        needed. FSA &amp; HSA accepted.
      </p>

      <!-- CTA row -->
      <div
        style="display: flex; flex-direction: column; align-items: center; gap: 12px;"
      >
        <!-- Primary CTA -->
        <a
          href="#hero-form"
          style="display: inline-block; background: var(--orange); color: var(--white); font-family: var(--font-body); font-weight: 700; font-size: 14px; letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none; padding: 16px 32px; border-radius: var(--radius-btn, 6px);"
        >
          BOOK YOUR 60-MINUTE VISIT
        </a>

        <!-- Secondary CTAs -->
        <div
          style="display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;"
        >
          <a
            href="tel:+18663444955"
            style="display: inline-flex; align-items: center; gap: 8px; background: transparent; color: var(--white); font-family: var(--font-body); font-weight: 700; font-size: 14px; letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none; padding: 14px 24px; border-radius: var(--radius-btn, 6px); border: 1px solid rgba(255,255,255,0.30);"
          >
            <!-- Phone icon -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.65 3.09 2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9a16 16 0 0 0 6.91 6.91l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
            Call
          </a>

          <a
            href="sms:+18663444955?body=Hi%2C%20I%27d%20like%20to%20book%20a%20visit."
            style="display: inline-flex; align-items: center; gap: 8px; background: transparent; color: var(--white); font-family: var(--font-body); font-weight: 700; font-size: 14px; letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none; padding: 14px 24px; border-radius: var(--radius-btn, 6px); border: 1px solid rgba(255,255,255,0.30);"
          >
            <!-- MessageCircle icon -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
            </svg>
            Text
          </a>
        </div>
      </div>

      <!-- Trust microcopy -->
      <p
        style="font-family: var(--font-body); font-size: 13px; color: rgba(255,255,255,0.50); margin-top: 28px; letter-spacing: 0.02em;"
      >
        3 Virginia locations &middot; HIPAA compliant &middot; LegitScript certified
      </p>
    </div>
  </div>
</section>
