---
import { TESTIMONIALS, GBP_REVIEWS_URL } from '../data/testimonials';
---

<section style="background: var(--cro-surface-secondary, #ECEAE6); padding: var(--section-y) var(--gutter);">
  <div style="max-width: var(--maxw); margin: 0 auto;">
    <!-- Header -->
    <div style="text-align: center; margin-bottom: 16px;">
      <p style="font-family: var(--font-body); font-size: var(--fs-eyebrow); font-weight: 700; letter-spacing: var(--ls-eyebrow); text-transform: uppercase; color: var(--orange, #E8670A); margin: 0 0 12px;">MEMBER STORIES</p>
      <h2 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(28px, 4vw, 48px); color: var(--cro-text-on-light, #0B1029); text-transform: uppercase; line-height: var(--lh-heading); margin: 0 0 20px;">Real Members. Real Experiences.</h2>
    </div>

    <!-- Aggregate rating strip -->
    <div style="display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 48px;">
      <span style="display: flex; align-items: center; gap: 2px;">
        {Array.from({length: 5}).map(() => (
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#C9A961" aria-hidden="true">
            <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
          </svg>
        ))}
      </span>
      <span style="font-family: var(--font-body); font-size: 14px; color: var(--cro-text-body, #374151); font-weight: 600;">4.9 average · 191 verified Google reviews</span>
      <a href={GBP_REVIEWS_URL} target="_blank" rel="noopener noreferrer" style="font-family: var(--font-body); font-size: 13px; color: var(--orange, #E8670A); font-weight: 700; text-decoration: none;">View all →</a>
    </div>

    <!-- Cards grid: 1-col mobile, 3-col desktop -->
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
      {TESTIMONIALS.map((t) => (
        <div style="background: #FFFFFF; border-radius: 20px; box-shadow: var(--shadow-card); padding: 24px; display: flex; flex-direction: column; gap: 14px;">
          <!-- Profile + name -->
          <div style="display: flex; align-items: center; gap: 12px;">
            {t.photoUrl && (
              <img src={t.photoUrl} alt={t.name} loading="lazy" width="44" height="44" style="width: 44px; height: 44px; border-radius: 50%; object-fit: cover; flex-shrink: 0;" />
            )}
            {!t.photoUrl && (
              <div style="width: 44px; height: 44px; border-radius: 50%; background: var(--navy, #0B1029); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <span style="font-family: var(--font-display); font-size: 18px; font-weight: 700; color: #fff;">{t.name.charAt(0)}</span>
              </div>
            )}
            <div>
              <p style="font-family: var(--font-body); font-size: 14px; font-weight: 700; color: var(--cro-text-on-light, #0B1029); margin: 0 0 2px;">{t.name}</p>
              <p style="font-family: var(--font-body); font-size: 12px; color: var(--body-gray, #6B7280); margin: 0;">{t.relativeTime}</p>
            </div>
          </div>

          <!-- Stars -->
          <span style="display: flex; align-items: center; gap: 2px;">
            {Array.from({length: 5}).map(() => (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#C9A961" aria-hidden="true">
                <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
              </svg>
            ))}
          </span>

          <!-- Quote -->
          <p style="font-family: var(--font-body); font-size: 14px; color: var(--cro-text-body, #374151); line-height: 1.65; margin: 0; flex: 1;">"{t.quote}"</p>

          <!-- Badge -->
          <div style="display: flex; align-items: center; gap: 6px; padding-top: 8px; border-top: 1px solid rgba(11,16,41,0.06);">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z" fill="#4285F4"/>
              <path d="M12 11h5.5a5.5 5.5 0 1 1-5.5-5.5V11z" fill="#fff" opacity=".8"/>
            </svg>
            <span style="font-family: var(--font-body); font-size: 11px; color: var(--body-gray, #6B7280); font-weight: 600; letter-spacing: 0.05em;">Verified Google Review</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
