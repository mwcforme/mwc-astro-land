---
const items = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--brand-cta)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>`,
    title: "No Referral Needed",
    desc: "Book directly — no GP sign-off required.",
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--brand-cta)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3H5a2 2 0 00-2 2v3m18 0V5a2 2 0 00-2-2h-3m0 18h3a2 2 0 002-2v-3M3 16v3a2 2 0 002 2h3"/></svg>`,
    title: "On-Site Blood Draw",
    desc: "Full hormone panel drawn in-center, no outside lab visit.",
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--brand-cta)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: "Same-Visit Results",
    desc: "Labs reviewed with your provider in the same 60-minute appointment.",
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--brand-cta)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
    title: "Real Conversation",
    desc: "A licensed provider explains every number in plain language.",
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--brand-cta)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
    title: "Treatment Same Day",
    desc: "When clinically appropriate, your protocol starts that visit.",
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--brand-cta)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>`,
    title: "No-Cost First Visit",
    desc: "Labs, provider time, and review — all included. No insurance needed.",
  },
];
---
<section style="background: var(--brand-cream); padding: 64px 24px;">
  <div class="max-w-[1100px] mx-auto">
    <div style="background: #0B1029; border-radius: 20px; padding: 48px 40px;">
      <p style="font-family: var(--font-body); font-size: 12px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--brand-cta-accessible); margin-bottom: 12px; text-align: center;">
        Your First Visit
      </p>
      <h2 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(26px, 3.5vw, 38px); color: var(--c-text-on-dark); text-transform: uppercase; text-align: center; margin-bottom: 40px; line-height: 1.1;">
        What To Expect At Your First Visit
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map((item) => (
          <div style="display: flex; flex-direction: column; align-items: flex-start; gap: 12px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12); border-radius: 12px; padding: 20px;">
            <div set:html={item.icon} />
            <h3 style="font-family: var(--font-display); font-weight: 700; font-size: 16px; color: var(--c-text-on-dark); text-transform: uppercase; margin: 0;">{item.title}</h3>
            <p style="font-family: var(--font-body); font-size: 14px; color: var(--c-text-on-dark-muted); line-height: 1.55; margin: 0;">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
