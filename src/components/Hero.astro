---
import { GBP_REVIEWS_URL } from '../data/testimonials';
import HeroLeadForm from './HeroLeadForm';
---
<section
  id="hero"
  style="background: var(--brand-navy-deep); padding-top: 64px; min-height: 720px; display: flex; align-items: center;"
>
  <div class="max-w-[1200px] mx-auto px-6 py-12 lg:py-16 w-full grid grid-cols-1 lg:grid-cols-[1fr_460px] gap-10 lg:gap-12 items-center">
    <!-- Left: copy -->
    <div>
      <!-- Eyebrow -->
      <p style="font-family: var(--font-body); font-size: 12px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--brand-cta-accessible); margin-bottom: 16px;">
        Virginia's Provider-Led Men's Health Clinic
      </p>

      <!-- H1: single element with two spans -->
      <h1 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(32px, 5vw, 58px); line-height: 1.05; text-transform: uppercase; margin: 0 0 20px;">
        <span style="display: block; color: var(--c-text-on-dark);">YOUR GP SAID<br />YOU'RE FINE.</span>
        <span style="display: block; color: var(--brand-cta);">YOU DON'T<br />FEEL FINE.</span>
      </h1>

      <!-- Star rating -->
      <a
        href={GBP_REVIEWS_URL}
        target="_blank"
        rel="noopener noreferrer"
        style="display: inline-flex; align-items: center; gap: 8px; text-decoration: none; margin-bottom: 24px;"
        aria-label="4.9 stars · 191 verified Google reviews"
      >
        <div style="display: flex; align-items: center; gap: 2px;">
          {[1,2,3,4,5].map(() => (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--brand-cta)" stroke="var(--brand-cta)" stroke-width="1" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          ))}
        </div>
        <span style="font-family: var(--font-body); font-size: 15px; font-weight: 700; color: var(--c-text-on-dark);">4.9</span>
        <span style="font-family: var(--font-body); font-size: 13px; color: var(--c-text-on-dark-muted);">· 191 verified Google reviews</span>
      </a>

      <!-- Symptom bullets -->
      <ul style="list-style: none; padding: 0; margin: 0 0 24px; display: flex; flex-direction: column; gap: 10px;">
        {[
          "You're tired by noon. Coffee stopped working.",
          "You're training just as hard. Your body stopped responding.",
          "Your drive is down. For work, the gym, her.",
          "Your doctor ran labs. Said everything is normal. You don't feel normal.",
          "You don't need a pep talk. You need someone to look at the data.",
        ].map((symptom) => (
          <li style="display: flex; align-items: flex-start; gap: 10px; font-family: var(--font-body); font-size: 15px; color: var(--c-text-on-dark-muted); line-height: 1.5;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brand-cta)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink: 0; margin-top: 2px;"><polyline points="9 18 15 12 9 6"/></svg>
            {symptom}
          </li>
        ))}
      </ul>

      <!-- Body copy -->
      <p style="font-family: var(--font-body); font-size: 16px; color: var(--c-text-on-dark-muted); line-height: 1.7; margin-bottom: 28px;">
        Your GP checked the basics and said you're fine. You're not fine. We specialize in men's hormones, ED, and weight loss. It's all we do. That focus is the difference.
      </p>

      <!-- No-cost badge -->
      <div style="display: inline-flex; align-items: center; gap: 8px; background: rgba(232,103,10,0.15); border: 1px solid rgba(232,103,10,0.35); border-radius: 60px; padding: 8px 16px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brand-cta)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        <span style="font-family: var(--font-body); font-size: 13px; font-weight: 700; color: var(--brand-cta); text-transform: uppercase; letter-spacing: 0.08em;">No-cost visit · Same-day labs</span>
      </div>
    </div>

    <!-- Right: lead form React island -->
    <div id="hero-form" style="scroll-margin-top: 80px; display: flex; justify-content: center;">
      <HeroLeadForm client:load />
    </div>
  </div>
</section>
