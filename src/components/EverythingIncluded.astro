---
const INCLUDED = [
  "Labs drawn and reviewed on-site",
  "60-minute face-to-face provider visit",
  "Personalized treatment protocol (if appropriate)",
  "We do not accept insurance, but FSA, HSA, and financing options are available",
  "No phone tag or waiting rooms",
  "Virginia-licensed providers, every visit",
];

const NOT_INCLUDED = [
  "Hidden fees",
  "Automatic subscriptions",
  "Pressure to commit",
  "Call center routing",
];
---
<section style="scroll-margin-top: 64px; background: var(--brand-navy-deep);">
  <div class="max-w-[1100px] mx-auto px-6 py-16 md:py-20">
    <!-- Heading -->
    <div class="text-center mb-12">
      <p style="font-family: var(--font-body); font-size: 12px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--brand-cta-accessible); margin-bottom: 12px;">
        What's Covered
      </p>
      <h2 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(26px, 3.5vw, 40px); color: var(--brand-cream); line-height: 1.1; margin-bottom: 12px; text-transform: uppercase;">
        EVERYTHING'S INCLUDED.<br />
        <span style="color: var(--brand-cta);">NO SURPRISES.</span>
      </h2>
      <p style="font-size: 17px; max-width: 520px; font-family: var(--font-body); color: var(--c-text-on-dark-muted); line-height: 1.6; margin: 0 auto;">
        Your first visit is no-cost. Here's exactly what that means.
      </p>
    </div>

    <!-- Two-column cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
      <!-- Included -->
      <div style="border: 1px solid rgba(255,255,255,0.35); padding: 28px; border-radius: 16px; background: rgba(255,255,255,0.06);">
        <p style="text-transform: uppercase; font-size: 13px; margin-bottom: 20px; font-family: var(--font-display); font-weight: 700; letter-spacing: 0.10em; color: var(--brand-cta);">
          ✓ What's included
        </p>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 14px;">
          {INCLUDED.map((item) => (
            <li style="display: flex; align-items: flex-start; gap: 12px; font-size: 16px; font-family: var(--font-body); color: var(--c-text-on-dark); line-height: 1.5;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--brand-cta)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink: 0; margin-top: 2px;"><polyline points="20 6 9 17 4 12"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Not included -->
      <div style="border: 1px solid rgba(255,255,255,0.35); padding: 28px; border-radius: 16px; background: rgba(255,255,255,0.06);">
        <p style="text-transform: uppercase; font-size: 13px; margin-bottom: 20px; font-family: var(--font-display); font-weight: 700; letter-spacing: 0.10em; color: rgba(255,255,255,0.50);">
          ✗ What you won't find here
        </p>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 14px;">
          {NOT_INCLUDED.map((item) => (
            <li style="display: flex; align-items: flex-start; gap: 12px; font-size: 16px; font-family: var(--font-body); color: var(--c-text-on-dark-muted); line-height: 1.5;">
              <span aria-hidden="true" style="font-size: 16px; margin-top: 2px; color: rgba(255,255,255,0.50); font-weight: 700; flex-shrink: 0; line-height: 1;">&#x2715;</span>
              {item}
            </li>
          ))}
        </ul>

        <!-- Stat callout -->
        <div style="border-top: 1px solid rgba(255,255,255,0.20); text-align: center; margin-top: 28px; padding-top: 24px;">
          <div style="font-size: 44px; font-family: var(--font-display); font-weight: 700; color: var(--brand-cta);">10,000+</div>
          <div style="font-size: 14px; margin-top: 6px; font-family: var(--font-body); color: var(--c-text-on-dark-subtle); line-height: 1.4;">
            Virginia members since 2015.<br />All at no-cost for the first visit.
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
