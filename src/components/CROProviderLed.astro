---
/**
 * CROProviderLed — "Provider-Led. Virginia-Local. Built for Men."
 * 4-card feature grid on dark navy background.
 * Desktop: 4 columns. Tablet: 2x2. Mobile: 1 column.
 */

interface ProviderCard {
  photo: string;
  photoAlt: string;
  title: string;
  body: string;
}

const CARDS: ProviderCard[] = [
  {
    photo: "/assets/lp/doctor-patient-exam.webp",
    photoAlt: "Licensed provider at Men's Wellness Centers",
    title: "LICENSED PROVIDERS",
    body: "Licensed Virginia providers and nurse practitioners. A real provider, every visit.",
  },
  {
    photo: "/assets/lp/exam-room-blood-draw.webp",
    photoAlt: "On-site lab draw at Men's Wellness Centers",
    title: "ON-SITE LABS",
    body: "CLIA-certified lab in every center. No third-party lab visit, no waiting a week for results.",
  },
  {
    photo: "/assets/lp/man-confident-gray-hair-earbuds-2.webp",
    photoAlt: "Man focused on men's wellness",
    title: "BUILT FOR MEN",
    body: "TRT, ED, and weight loss is all we do. Dedicated focus means faster answers and better outcomes.",
  },
];
---

<section
  style="background: #0B1029; padding: clamp(48px, 8vw, 80px) clamp(16px, 4vw, 32px);"
>
  <div style="max-width: var(--maxw); margin: 0 auto;">
    <h2
      class="cro-provider-led-headline"
      style="font-family: Oswald, sans-serif; font-weight: 700; text-transform: uppercase; text-align: center; color: #FFFFFF; line-height: 1.1; margin-bottom: clamp(32px, 5vw, 56px);"
    >
      PROVIDER-LED. VIRGINIA-LOCAL. BUILT FOR MEN.
    </h2>

    <div class="cro-provider-led-grid">
      {CARDS.map((card) => (
        <div
          class="cro-provider-card"
          style="background: #161B3A; border: 1px solid #1E244A; border-radius: var(--radius); padding: 24px; display: flex; flex-direction: column; align-items: center; text-align: center;"
        >
          <img
            src={card.photo}
            alt={card.photoAlt}
            loading="lazy"
            width={80}
            height={80}
            style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; object-position: center top; flex-shrink: 0;"
          />
          <p
            style="font-family: Oswald, sans-serif; font-weight: 700; font-size: 12px; text-transform: uppercase; letter-spacing: 0.1em; color: #E8670A; margin-top: 16px; margin-bottom: 8px;"
          >
            {card.title}
          </p>
          <p
            style="font-family: Montserrat, sans-serif; font-size: 14px; color: #FFFFFF; line-height: 1.6; margin: 0;"
          >
            {card.body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .cro-provider-led-headline {
    font-size: 32px;
  }
  @media (min-width: 1024px) {
    .cro-provider-led-headline {
      font-size: 48px;
    }
  }

  .cro-provider-led-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 640px) {
    .cro-provider-led-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 1024px) {
    .cro-provider-led-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .cro-provider-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .cro-provider-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }
</style>
