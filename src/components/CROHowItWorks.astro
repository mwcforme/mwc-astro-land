---
/**
 * CROHowItWorks — "Here's how it works in one visit"
 * Three numbered steps.
 */

interface Step {
  number: number;
  title: string;
  description: string;
  isLast?: boolean;
}

const STEPS: Step[] = [
  {
    number: 1,
    title: "Book Online In Under 5 Minutes",
    description:
      "Pick the location and time that works for you. No referral, no phone tag.",
  },
  {
    number: 2,
    title: "A Provider Who Actually Explains Your Labs",
    description:
      "A licensed provider who specializes in men's health sits with you, goes over every number, and tells you exactly what's driving your symptoms.",
  },
  {
    number: 3,
    title: "Walk Out With Your Protocol Locked In",
    description:
      "A care plan built around your labs and your goals. Most members start treatment the same visit.",
    isLast: true,
  },
];
---

<section
  id="how-it-works"
  style="background: var(--cro-surface-secondary); padding: var(--section-y) 24px;"
>
  <div style="max-width: 720px; margin: 0 auto;">
    <!-- Eyebrow + Heading -->
    <p style="font-family: var(--font-body); font-weight: 700; font-size: 0.8125rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--orange); margin-bottom: 12px; text-align: center;">
      THE PROCESS
    </p>
    <div style="text-align: center; margin-bottom: 48px;">
      <h2 style="font-family: var(--font-display); font-size: var(--fs-h1); font-weight: 700; text-transform: uppercase; line-height: 1.05; color: var(--navy); margin: 0;">
        HERE&rsquo;S HOW IT WORKS IN ONE VISIT
      </h2>
    </div>

    <!-- Steps -->
    <div style="display: flex; flex-direction: column; gap: 40px; margin-bottom: 48px;">
      {STEPS.map((step) => (
        <div
          style={`display: flex; gap: 20px; align-items: flex-start; background: var(--white); border-radius: var(--cro-card-radius); border: 1px solid rgba(11,16,41,0.10); box-shadow: var(--shadow-card); padding: 28px 32px;`}
        >
          <!-- Numbered circle -->
          <div
            style={`width: 48px; height: 48px; min-width: 48px; border-radius: 50%; background: ${step.isLast ? "var(--orange)" : "var(--navy)"}; color: var(--white); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-weight: 700; font-size: 1.25rem; font-variant-numeric: tabular-nums; box-shadow: ${step.isLast ? "0 0 0 4px rgba(232,103,10,0.20), 0 8px 24px rgba(232,103,10,0.30)" : "none"};`}
          >
            {step.number}
          </div>

          <!-- Text -->
          <div>
            <h3
              style="font-family: var(--font-body); font-weight: 700; font-size: 1.125rem; color: var(--navy); margin-bottom: 6px;"
            >
              {step.title}
            </h3>
            <p
              style="font-family: var(--font-body); font-size: var(--fs-body); color: var(--cro-text-body); line-height: 1.65; margin: 0;"
            >
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div style="text-align: center;">
      <a
        href="#hero-form"
        style="display: inline-block; background: var(--orange); color: var(--white); font-family: var(--font-body); font-weight: 700; font-size: 14px; letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none; padding: 16px 32px; border-radius: var(--radius-btn, 6px);"
      >
        BOOK YOUR 60-MINUTE VISIT
      </a>
    </div>
  </div>
</section>
