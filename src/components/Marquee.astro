---
---
<section
  aria-label="Certifications and credentials"
  style="border-top: 1px solid rgba(255,255,255,0.07); border-bottom: 1px solid rgba(255,255,255,0.07); background: var(--brand-navy-deep);"
>
  <div
    style="padding: 28px 24px; gap: 24px 56px; display: flex; flex-direction: row; flex-wrap: wrap; align-items: center; justify-content: center; max-width: 960px; margin: 0 auto;"
  >
    <img
      src="/images/badges/clia-color.webp"
      alt="Clinical Laboratory Improvements Amendments"
      style="height: 56px; width: auto; object-fit: contain;"
      loading="lazy"
      decoding="async"
      width="120"
      height="56"
    />

    <a
      href="https://www.legitscript.com/websites/?checker_keywords=menswellnesscenters.com"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Verify LegitScript Certification for menswellnesscenters.com"
      style="display: inline-block;"
    >
      <img
        src="/images/badges/legitscript-color.webp"
        alt="LegitScript Certified Healthcare Website"
        style="height: 72px; width: auto; object-fit: contain;"
        loading="lazy"
        decoding="async"
        width="110"
        height="72"
      />
    </a>

    <img
      src="/images/badges/hipaa-color.webp"
      alt="Health Insurance Portability and Accountability Act"
      style="height: 56px; width: auto; object-fit: contain;"
      loading="lazy"
      decoding="async"
      width="120"
      height="56"
    />
  </div>
</section>
