---
---
<div
  style="background: var(--brand-navy); padding: 12px 16px; width: 100%;"
  class="flex flex-col items-center gap-2"
>
  <div class="flex items-center justify-center gap-5 flex-wrap">
    <img
      src="/images/badges/hipaa-color.webp"
      alt="HIPAA Compliant"
      style="height: 36px; width: auto; display: block;"
      loading="lazy"
      decoding="async"
      width="120"
      height="36"
    />
    <img
      src="/images/badges/clia-color.webp"
      alt="CLIA Certified"
      style="height: 36px; width: auto; display: block;"
      loading="lazy"
      decoding="async"
      width="120"
      height="36"
    />
    <a
      href="https://www.legitscript.com/websites/?checker_keywords=menswellnesscenters.com"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="LegitScript Verified: view certification"
      style="display: inline-flex; align-items: center;"
    >
      <img
        src="/images/badges/legitscript-color.webp"
        alt="LegitScript Verified"
        style="height: 36px; width: auto; display: block;"
        loading="lazy"
        decoding="async"
        width="110"
        height="36"
      />
    </a>
  </div>
  <p style="font-family: var(--font-body); font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.55); margin: 0; text-align: center; line-height: 1;">
    HIPAA Compliant&nbsp;&middot;&nbsp;CLIA Certified&nbsp;&middot;&nbsp;LegitScript Verified
  </p>
</div>
