---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  schemaJson?: string;
}
const { title, description, schemaJson } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/webp" href="/logos/mwc-logo-navy.webp" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet" />
  {schemaJson && <script is:inline type="application/ld+json" set:html={schemaJson} />}
</head>
<body class="font-sans overflow-x-hidden">
  <slot />
</body>
</html>
